{
  "datasets": [
    {
      "name": "aa6a6f58",
      "displayName": "E_E_Cricket_Analytics_Dashboard",
      "queryLines": [
        "select * from cricket_dev.silver.cricket_matches_final "
      ],
      "columns": [
        {
          "displayName": "Toss Winner Won Match",
          "description": "Whether the team that won the toss also won the match",
          "expression": "`toss_winner` = `winner`"
        }
      ]
    },
    {
      "name": "58a17f41",
      "displayName": "Total Cricket Matches Count",
      "queryLines": [
        "SELECT COUNT(*) AS total_matches\r\n",
        "FROM `cricket_dev`.`silver`.`cricket_matches_final`"
      ]
    },
    {
      "name": "90fdc08b",
      "displayName": "Untitled dataset 1",
      "queryLines": [
        ""
      ]
    },
    {
      "name": "top5_teams",
      "displayName": "Top 5 Teams with Most Wins",
      "queryLines": [
        "SELECT\n",
        "  winner_team,\n",
        "  COUNT(*) as wins\n",
        "FROM\n",
        "  cricket_dev.silver.cricket_matches_final\n",
        "WHERE\n",
        "  winner_team IS NOT NULL\n",
        "GROUP BY\n",
        "  winner_team\n",
        "ORDER BY\n",
        "  wins DESC\n",
        "LIMIT 5"
      ]
    },
    {
      "name": "win_percentage",
      "displayName": "Win Percentage by Team",
      "queryLines": [
        "WITH team_matches AS (\n",
        "  SELECT\n",
        "    team1 AS team\n",
        "  FROM\n",
        "    cricket_matches_final\n",
        "  UNION ALL\n",
        "  SELECT\n",
        "    team2 AS team\n",
        "  FROM\n",
        "    cricket_matches_final\n",
        "),\n",
        "match_counts AS (\n",
        "  SELECT\n",
        "    team,\n",
        "    COUNT(*) as total_matches\n",
        "  FROM\n",
        "    team_matches\n",
        "  WHERE\n",
        "    team IS NOT NULL\n",
        "  GROUP BY\n",
        "    team\n",
        "),\n",
        "win_counts AS (\n",
        "  SELECT\n",
        "    winner_team as team,\n",
        "    COUNT(*) as wins\n",
        "  FROM\n",
        "    cricket_matches_final\n",
        "  WHERE\n",
        "    winner_team IS NOT NULL\n",
        "  GROUP BY\n",
        "    winner_team\n",
        ")\n",
        "SELECT\n",
        "  m.team,\n",
        "  COALESCE(w.wins, 0) as wins,\n",
        "  m.total_matches,\n",
        "  (COALESCE(w.wins, 0) * 100.0 / m.total_matches) as win_percentage\n",
        "FROM\n",
        "  match_counts m\n",
        "    LEFT JOIN win_counts w\n",
        "      ON m.team = w.team\n",
        "ORDER BY\n",
        "  win_percentage DESC"
      ],
      "catalog": "cricket_dev",
      "schema": "silver"
    }
  ],
